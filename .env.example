# =============================================================================
#  poly_bot 环境配置
#  Environment Configuration
#
#  复制为 .env 后填写必填项:
#  Copy to .env and fill required fields:
#    cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# [1] 账户认证
#     Account & Authentication  REQUIRED
# -----------------------------------------------------------------------------

# Polymarket 私钥（64 位 hex，可带或不带 0x 前缀）
# Private key (64-char hex, with or without 0x prefix)
# 邮箱/Magic 账号: https://reveal.magic.link/polymarket
# Email/Magic: https://reveal.magic.link/polymarket
# 浏览器钱包: 导出对应 EOA 私钥
# Browser wallet: export your EOA private key
POLYMARKET_PRIVATE_KEY=

# 资金托管地址（Settings 里显示的 Address，非 EOA 签名地址）
# Funder address from Polymarket Settings (NOT your EOA signer address)
# https://polymarket.com/settings?tab=builder → Address
# 邮箱与浏览器钱包在 V2 下通常均为 deposit wallet，填 Settings 地址即可
# For V2, both email and browser accounts usually use the deposit wallet from Settings
POLYMARKET_PROXY_ADDRESS=


# -----------------------------------------------------------------------------
# [2] Builder API  REQUIRED for Merge
#     Merge / Redeem 前必须填写
# -----------------------------------------------------------------------------

# 在 Polymarket → Settings → Builders → Create New 获取
# Get from Polymarket → Settings → Builders → Create New
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=


# -----------------------------------------------------------------------------
# [3] CLOB 接口
#     CLOB API  optional
# -----------------------------------------------------------------------------

# API 地址 — 使用 https://clob.polymarket.com（不要用 clob-v2.polymarket.com）
# API endpoint — use https://clob.polymarket.com (NOT clob-v2.polymarket.com)
CLOB_API_URL=https://clob.polymarket.com

# 签名类型 — 按「资金托管钱包类型」选择，与登录方式（邮箱/钱包）无必然对应
# Signature type — based on funder wallet type, NOT login method (email vs browser)
#
#   Poly1271 | deposit | 3  — V2 deposit wallet（默认；邮箱/Magic 与浏览器钱包均适用）
#   Poly1271 | deposit | 3  — V2 deposit wallet (default; email/Magic and browser wallet)
#
#   Proxy | magic | email    — 仅 V1 旧 Magic 代理（Settings 地址 = ProxyFactory 推导地址）
#   Proxy | magic | email    — legacy Magic proxy only (Settings addr = ProxyFactory derive)
#
#   GnosisSafe | safe         — Gnosis Safe
#   Eoa | 0                   — 纯 EOA 直连（无需 POLYMARKET_PROXY_ADDRESS）
#   Eoa | 0                   — direct EOA (no POLYMARKET_PROXY_ADDRESS)
#
# 若 Proxy 下单报 "please use the deposit wallet flow" → 改用 Poly1271
# If Proxy orders fail with "please use the deposit wallet flow" → use Poly1271
SIGNATURE_TYPE=Poly1271

# -----------------------------------------------------------------------------
# [4] 链上 & Relayer
#     On-chain & Relayer  optional
# -----------------------------------------------------------------------------

RELAYER_URL=https://relayer-v2.polymarket.com

# Merge / Redeem 输出代币（默认 pUSD）
# Output token after Merge or Redeem (default: pUSD)
MERGE_OUTPUT_TOKEN=pUSD

# Merge 后自动 wrap 为 pUSD
# Auto-wrap merge proceeds to pUSD via Collateral Onramp
MERGE_WRAP_TO_PUSD=true
REDEEM_OUTPUT_TOKEN=pUSD

# Polygon RPC（不填则使用内置公共节点 publicnode/allnodes，免费档限流 1200rqs/60s）
# wind-down 批量 merge/redeem 易触发 429，建议设为私有/付费 RPC(Alchemy/Infura/自建)避免限流
# Polygon RPC (built-in public node if unset; free tier is rate-limited to 1200rqs/60s.
#   Set a private/paid RPC to avoid 429 during batch merge/redeem)
# RPC_URL=https://polygon-bor-rpc.publicnode.com

# Safe 直发交易（Poly1271/GnosisSafe 钱包的 merge/redeem/wrap）的 gas 费率上限，单位 gwei。
# 签名 EOA 需持有 POL 支付 gas。alloy 默认把 maxFeePerGas 估成 ~2×baseFee，
# 费率骤升时会按 gasLimit×maxFeePerGas 预扣，可能超出余额而报 "insufficient funds"。
# 下方上限用于避免过度预扣；默认 300/30 gwei（远高于 Polygon 常态，且不会像 2×baseFee 那样过度预扣）。
# 若因骤升导致交易长时间不上链，可上调 TX_MAX_FEE_GWEI。
# Fee caps (gwei) for Safe execTransaction; signing EOA must hold POL for gas.
# TX_MAX_FEE_GWEI=300
# TX_PRIORITY_FEE_GWEI=30


# -----------------------------------------------------------------------------
# [5] 市场发现
#     Market Discovery  optional
# -----------------------------------------------------------------------------

# 监控的加密货币符号，逗号分隔
# Comma-separated crypto symbols to monitor
CRYPTO_SYMBOLS=btc,eth,sol,xrp,doge,hype,bnb

# 距下一窗口结束前多少秒刷新市场
# Seconds before next window ends to refresh markets
MARKET_REFRESH_ADVANCE_SECS=5


# -----------------------------------------------------------------------------
# [6] 套利 & 下单
#     Arbitrage & Orders  optional
# -----------------------------------------------------------------------------

# 最小利润阈值（0.001 = 0.1%）
# Min profit threshold (0.001 = 0.1%)
MIN_PROFIT_THRESHOLD=0.001

# 单笔最大下单量（USDC / pUSD）
# Max order size per trade (USDC / pUSD)
MAX_ORDER_SIZE_USDC=100.0

# 当前可用份额下限：min(YES best ask size, NO best ask size, MAX_ORDER_SIZE_USDC) 必须 >= 此值
# Minimum capped available shares before sizing down
ARBITRAGE_MIN_AVAILABLE_SHARES=20.0

# 实际提交份额比例：submit_size = capped_available_size * ratio（向下保留 2 位）
# Submitted size ratio; e.g. 0.8 submits 80% of capped available shares
ARBITRAGE_ORDER_SIZE_RATIO=0.8

# 执行条件: yes + no <= 1 - spread（如 spread=0.01 时在 0.99 执行）
# Execute when yes + no <= 1 - spread (e.g. spread=0.01 triggers at 0.99)
ARBITRAGE_EXECUTION_SPREAD=0.03

# YES/NO orderbook 时间戳最大允许偏差（毫秒），超过则跳过该次机会；修改后需重启
# Max allowed YES/NO orderbook timestamp skew in milliseconds; skip pairs above this; restart required
MAX_ORDERBOOK_PAIR_SKEW_MS=200

# YES / NO 价格下限，0 = 不限制
# Min YES/NO price; 0 = no filter
MIN_YES_PRICE_THRESHOLD=0.3
MIN_NO_PRICE_THRESHOLD=0.3

# 滑点/价格缓冲 [first, second]: 下降侧用 second，上涨/持平用 first，仅影响提交限价
# Slippage/price buffer [first, second]: use second for declining side, first for rising/flat; affects submitted limit prices
SLIPPAGE=0.01,0.01

# 是否要求加上 SLIPPAGE 后的 YES+NO 仍满足执行阈值；false 表示只按原始 best ask 做执行阈值校验
# Require slippage-adjusted YES+NO to satisfy the execution threshold; false checks raw best ask only
ARBITRAGE_VALIDATE_SLIPPAGE_ADJUSTED_TOTAL=false

# 订单类型: GTC | GTD | FOK | FAK
#   GTC/GTD：并发下单两腿、窗口内不自动撤单；GTC 无到期，靠窗口切换时 cancel_all 清理，GTD 靠到期清理
#   FOK/FAK：即时成交型（IOC），不留挂单
# Order type: GTC | GTD | FOK | FAK
#   GTC/GTD: both legs sent concurrently, no auto-cancel within the window; GTC has
#            no expiry (cleared by cancel_all at window switch), GTD clears by expiry
#   FOK/FAK: immediate-or-cancel (IOC), never rest
ARBITRAGE_ORDER_TYPE=GTC

# GTD 订单过期时间（秒），仅 ARBITRAGE_ORDER_TYPE=GTD 时生效
# GTD order expiry in seconds (only when ARBITRAGE_ORDER_TYPE=GTD)
GTD_EXPIRATION_SECS=300

# 两腿成交不平衡时的处理窗口（秒）
#   GTD：并发提交两腿后等待继续成交的宽限时间，随后仅快照成交量，两腿原地挂着不撤单（靠 GTD 到期自然清理）
#   GTC：同 GTD（并发提交后快照成交量、原地挂着不撤单）；无到期，靠窗口切换 cancel_all 清理
#   FOK/FAK：主动补齐缺腿的时间窗（仅在补完仍有利可图时追单），超时则市价平掉多的一边
#   5 分钟市场建议取小值（如 3 秒）
# Reconciliation window (seconds) for an imbalanced pair:
#   GTD: grace period after concurrent submission, then snapshot fills only — both legs are left resting (no auto-cancel; the GTD expiry cleans them up)
#   GTC: same as GTD (snapshot fills after concurrent submit, left resting, no auto-cancel); no expiry, cleared at window switch
#   FOK/FAK: window to actively top up the under-filled leg (only while still profitable),
#            then market-unwind the over-filled leg. Keep small (e.g. 3s) for 5-min markets.
ARBITRAGE_HEDGE_GRACE_SECS=3


# -----------------------------------------------------------------------------
# [7] 风控 & 收尾
#     Risk & Wind-down  optional
# -----------------------------------------------------------------------------

# 每轮最大风险敞口（USDC）
# Max exposure per round (USDC)
RISK_MAX_EXPOSURE_USDC=1000.0

# 持仓不平衡阈值（0.1 = 10%）
# Position imbalance threshold (0.1 = 10%)
RISK_IMBALANCE_THRESHOLD=0.1

# 对冲止盈 / 止损比例
# Hedge take-profit / stop-loss ratio
HEDGE_TAKE_PROFIT_PCT=0.05
HEDGE_STOP_LOSS_PCT=0.05

# 市场结束前 N 秒停止套利，0 = 不限制
# Stop arbitrage N seconds before market end; 0 = no limit
STOP_ARBITRAGE_BEFORE_END_SECONDS=90

# 窗口结束前收尾（取消挂单 → Merge → 市价卖剩余），0 = 关闭
# Wind-down before window end (cancel orders → Merge → market sell remainder); 0 = disabled
WIND_DOWN_BEFORE_WINDOW_END_SECONDS=0

# 收尾时单腿卖出限价
# Limit price for single-leg sell during wind-down
WIND_DOWN_SELL_PRICE=0.01

# 定时 Merge 间隔（分钟），0 = 关闭
# Scheduled Merge interval in minutes; 0 = disabled
MERGE_INTERVAL_MINUTES=0


# -----------------------------------------------------------------------------
# [8] 持仓同步
#     Position Sync  optional
# -----------------------------------------------------------------------------

# 持仓同步间隔（秒）
# Position sync interval in seconds
POSITION_SYNC_INTERVAL_SECS=10

# 仓位平衡检查间隔（秒）。配合下方 START_BEFORE_END 使用：仅在窗口末段生效，
#   故设为 1 表示进入末段后每秒检查一次；末段之外只是廉价的时间判断，不发请求。
# Position balance check interval in seconds. With START_BEFORE_END below it only
#   acts in the final stretch, so 1 = re-check ~once per second once inside that
#   window; outside it this is just a cheap time check with no API calls.
POSITION_BALANCE_INTERVAL_SECS=1

# 仅在窗口结束前 N 秒才启动仓位平衡（撤掉不平衡的多余挂单）；0=整个窗口都平衡。
#   例如 90：前 3.5 分钟 GTD 两腿原地挂着不撤，最后 90s 才开始每秒清理不平衡挂单。
#   建议与 STOP_ARBITRAGE_BEFORE_END_SECONDS 取相同值，末段只清理、不再开新套利。
# Only start position balancing in the final N seconds before window end (cancel
#   imbalanced excess orders); 0 = balance the whole window. e.g. 90: GTD legs
#   rest untouched for the first 3.5 min, then the last 90s cleans up imbalance
#   every second. Recommended equal to STOP_ARBITRAGE_BEFORE_END_SECONDS so the
#   final stretch only cleans up and opens no new arbitrage.
POSITION_BALANCE_START_BEFORE_END_SECS=90

# 不平衡阈值
# Imbalance threshold to trigger balance action
POSITION_BALANCE_THRESHOLD=2.0

# 最小总持仓要求
# Min total position required to run balance check
POSITION_BALANCE_MIN_TOTAL=5.0


# -----------------------------------------------------------------------------
# [9] 日志 & 界面
#     Logging & UI  optional
# -----------------------------------------------------------------------------

# 日志级别: trace | debug | info | warn | error
# Log level: trace | debug | info | warn | error
RUST_LOG=info

# 日志文件路径
# Log file path
# LOG_FILE=bot.log

# 启用终端 UI
# Enable terminal dashboard UI
# TUI_ENABLED=true

# 纯文本日志（关闭 TUI 着色）
# Plain-text logs (disable TUI styling)
# PLAIN_LOGS=false

# 启用 Web 控制台。远程部署时必须放在 HTTPS 反向代理后面，并设置 ADMIN_TOKEN
# Enable embedded web control console. For remote deployments, put it behind HTTPS reverse proxy and set ADMIN_TOKEN
# WEB_ENABLED=false

# Web 监听地址；Docker 内启用时通常使用 0.0.0.0:8080
# Web bind address; use 0.0.0.0:8080 inside Docker when enabled
# WEB_BIND=0.0.0.0:8080

# Web 控制台管理 Token。启用 WEB_ENABLED=true 时必填，不要提交到 Git
# Admin token for the web control console. Required when WEB_ENABLED=true; never commit it
# ADMIN_TOKEN=change-me-long-random-token

# 控制台状态文件路径。用于跨进程重启保留运行时参数；交易每次启动都默认暂停，需手动恢复；Docker 中建议挂载 /app/data
# Control state file path. Persists runtime config across process restarts; trading always starts paused and requires manual resume; mount /app/data in Docker
# CONTROL_STATE_PATH=data/control_state.json
